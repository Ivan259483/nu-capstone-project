# Backend API origin (no trailing /api). Use HTTPS in dev when testing WebAR/camera in-app WebView
# (mobile browsers require a secure context for getUserMedia).
#
# With ngrok — tunnel must point at **Express** (default PORT=3000), not Vite/Metro, or /api/bookings and
# POST /api/ai/scan return 404. Each `ngrok http` session gets a new URL; stale URLs show ERR_NGROK_3200 / offline.
#   cd backend && npm run dev   # or however you start Express on PORT (often 3000)
#   ngrok http 3000
# EXPO_PUBLIC_API_URL=https://your-subdomain.ngrok-free.dev
#
# Local LAN (HTTP) — Meshy + REST may work, but embedded WebAR camera will stay blocked.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Port used only when EXPO_PUBLIC_API_URL is unset (__DEV__ auto-detect from Expo LAN IP):
# EXPO_PUBLIC_DEV_API_PORT=3000
