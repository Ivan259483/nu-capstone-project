{
  "expo": {
    "name": "AutoSPF+",
    "slug": "autospf-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "autospfplus",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.autospf.plus",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "AutoSPF+ connects to the Metro JavaScript bundler on your Mac during local development (same Wi‑Fi).",
        "NSCameraUsageDescription": "Camera is used for vehicle scanning and AR damage inspection.",
        "NSMotionUsageDescription": "Motion sensors are used for the AR placement feature in the repair simulation viewer.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "permissions": [
        "INTERNET",
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F97316",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.autospf.plus",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "./plugins/withIosMetroLanHost.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F97316",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "./plugins/withRemoveIosPushEntitlement.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67bc1336-646f-4a64-b67a-888d73dcb8d9"
      }
    }
  }
}
