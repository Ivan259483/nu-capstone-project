generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PhotoType {
  BEFORE
  AFTER
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  role            UserRole          @default(CUSTOMER)
  membershipTier  MembershipTier?   @relation(fields: [membershipTierId], references: [id])
  membershipTierId String?
  rewardsBalance  RewardsBalance?
  vehicles        Vehicle[]
  bookings        Booking[]         @relation("CustomerBookings")
  assignedJobs    Booking[]         @relation("DetailerBookings")
  notesAuthored   CustomerNote[]    @relation("NoteAuthor")
  activityLogs    ActivityLog[]
  accounts        Account[]
  sessions        Session[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model MembershipTier {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  monthlyFee      Decimal  @default(0)
  discountPercent Int      @default(0)
  requiredPoints  Int      @default(0)
  users           User[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RewardsBalance {
  id        String              @id @default(cuid())
  user      User                @relation(fields: [userId], references: [id])
  userId    String              @unique
  points    Int                 @default(0)
  history   RewardsTransaction[]
  updatedAt DateTime            @updatedAt
  createdAt DateTime            @default(now())
}

model RewardsTransaction {
  id          String         @id @default(cuid())
  rewards     RewardsBalance @relation(fields: [rewardsId], references: [id])
  rewardsId   String
  points      Int
  reason      String
  createdAt   DateTime       @default(now())
}

model Vehicle {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  make      String
  model     String
  year      Int
  plate     String?
  color     String?
  bookings  Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  basePrice   Decimal  @default(0)
  durationMin Int      @default(60)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id            String            @id @default(cuid())
  customer      User              @relation("CustomerBookings", fields: [customerId], references: [id])
  customerId    String
  detailer      User?             @relation("DetailerBookings", fields: [detailerId], references: [id])
  detailerId    String?
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])
  vehicleId     String
  service       Service           @relation(fields: [serviceId], references: [id])
  serviceId     String
  status        BookingStatus     @default(PENDING)
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  totalPrice    Decimal           @default(0)
  customerNotes CustomerNote[]
  photos        BeforeAfterPhoto[]
  inventoryUsed InventoryUsage[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model InventoryItem {
  id           String            @id @default(cuid())
  name         String
  sku          String?           @unique
  description  String?
  unitCost     Decimal           @default(0)
  quantity     Int               @default(0)
  minQuantity  Int               @default(0)
  supplier     Supplier?         @relation(fields: [supplierId], references: [id])
  supplierId   String?
  usageLogs    InventoryUsage[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model InventoryUsage {
  id           String        @id @default(cuid())
  item         InventoryItem @relation(fields: [itemId], references: [id])
  itemId       String
  booking      Booking       @relation(fields: [bookingId], references: [id])
  bookingId    String
  quantityUsed Int           @default(1)
  createdAt    DateTime      @default(now())
}

model Supplier {
  id           String          @id @default(cuid())
  name         String          @unique
  contactName  String?
  email        String?
  phone        String?
  address      String?
  items        InventoryItem[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model BeforeAfterPhoto {
  id         String    @id @default(cuid())
  booking    Booking   @relation(fields: [bookingId], references: [id])
  bookingId  String
  type       PhotoType
  url        String
  createdAt  DateTime  @default(now())
}

model CustomerNote {
  id         String   @id @default(cuid())
  booking    Booking  @relation(fields: [bookingId], references: [id])
  bookingId  String
  author     User     @relation("NoteAuthor", fields: [authorId], references: [id])
  authorId   String
  note       String
  createdAt  DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
