{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "noImplicitAny": false,
        "noUnusedParameters": false,
        "skipLibCheck": true,
        "allowJs": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "noUnusedLocals": false,
        "strictNullChecks": false,
        "jsx": "react-jsx"
    },
    "include": ["src"]
}