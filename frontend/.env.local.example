# Copy to .env.local and adjust for your machine.
# Express must be reachable from the phone browser (same host you open for Next).

# ── Option A — ngrok (HTTPS tunnel to local API) ───────────────────────────
# NEXT_PUBLIC_API_URL=https://abcd-12-34-56-78.ngrok-free.app
# VITE_PUBLIC_API_URL=https://abcd-12-34-56-78.ngrok-free.app
# (ngrok forwards to e.g. http://localhost:8080 — run: ngrok http 8080)

# ── Option B — Cloudflare Tunnel ────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://random-name.trycloudflare.com

# ── Option C — mkcert HTTPS on Express (LAN IP, no tunnel) ────────────────
# Backend .env: HTTPS_KEY_PATH, HTTPS_CERT_PATH, PORT=8080
# NEXT_PUBLIC_API_URL=https://192.168.18.164:8080

# Optional: add your Next dev origin to backend CORS_ORIGIN if not using wildcard, e.g.
# CORS_ORIGIN=https://localhost:3100,https://192.168.18.164:3100
