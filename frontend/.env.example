# Local API (recommended for Vite dev — avoids proxy empty 500s). Default in code is http://localhost:3000/api when unset.
# VITE_API_URL=http://localhost:3000/api
# Optional: VITE_API_URL=/api (Vite proxy). In dev, `getBaseApiUrl()` upgrades `/api` to http://localhost:3000/api so login does not hit empty-body proxy 500s.
# VITE_API_URL=/api
# Production (Render):
# VITE_API_URL=https://nu-capstone-project.onrender.com/api
# VITE_BACKEND_URL=https://nu-capstone-project.onrender.com
# Run API + web together: from frontend/, `npm run dev:full`

# Firebase Configuration (Required for Social Login)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
