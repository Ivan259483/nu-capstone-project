PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/autospf
JWT_SECRET=your_jwt_secret_key_change_in_production
CORS_ORIGIN=http://localhost:5173

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Provider options: 'brevo', 'gmail', 'smtp', or 'console'
EMAIL_PROVIDER=brevo

# Professional Email Sender
EMAIL_FROM_NAME=AutoSPF+
EMAIL_FROM_ADDRESS=noreply@autospf.com

# ============================================
# BREVO (SENDINBLUE) CONFIGURATION
# Recommended: 300 free emails/day, custom domain support
# Sign up: https://www.brevo.com
# ============================================
BREVO_SMTP_USER=your_brevo_smtp_login
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
BREVO_API_KEY=your_brevo_api_key_optional

# ============================================
# GMAIL CONFIGURATION (FALLBACK)
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use app password (16 chars) below
# ============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# ============================================
# GENERIC SMTP CONFIGURATION (ALTERNATIVE)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ============================================
# AI DAMAGE + 3D GENERATION CONFIGURATION
# ============================================
GEMINI_API_KEY=your_gemini_api_key
MESHY_API_KEY=your_meshy_api_key
MESHY_API_BASE_URL=https://api.meshy.ai/openapi/v2

# Cloudinary is required for deterministic Meshy image-to-3D
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional unsigned mode if you use an upload preset instead of API secret:
# CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_UPLOAD_FOLDER=vehicle-scans

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_EXPIRY=600
OTP_LENGTH=6
