PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/autospf

# ─── REQUIRED SECRETS ─────────────────────────────────────────────────────
# Server WILL NOT START if either is missing.
# Generate JWT_SECRET:    python3 -c "import os,binascii; print(binascii.hexlify(os.urandom(64)).decode())"
# Generate ENCRYPTION_KEY: python3 -c "import os,binascii; print(binascii.hexlify(os.urandom(16)).decode())"
# ────────────────────────────────────────────────────────────────
JWT_SECRET=<128-char-hex-string>
ENCRYPTION_KEY=<32-char-hex-string>

CORS_ORIGIN=http://localhost:5173

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Provider options: 'resend', 'gmail', 'smtp', or 'console'
EMAIL_PROVIDER=resend

# Professional Email Sender
EMAIL_FROM_NAME=AutoSPF+
EMAIL_FROM_ADDRESS=verify@autospf.shop
EMAIL_REPLY_TO=support@autospf.shop
# Optional: full HTTPS URL to logo image for transactional emails (defaults to CLIENT_URL or CORS first origin + /autospf-logo.jpg). Prefer PNG with transparency or your official wordmark asset so the header matches brand in all clients.
# EMAIL_LOGO_URL=https://autospf.shop/images/autospf-logo.png
# Optional: public app URL for email links and default logo host (falls back to first CORS_ORIGIN or https://autospf.shop)
# CLIENT_URL=https://autospf.shop
# Optional: support address shown in transactional emails
SUPPORT_EMAIL=support@autospf.shop

# ============================================
# GMAIL CONFIGURATION (FALLBACK)
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use app password (16 chars) below
# ============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# ============================================
# GENERIC SMTP CONFIGURATION (ALTERNATIVE)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ============================================
# AI DAMAGE DETECTION — ROBOFLOW WORKFLOWS
# Sign up: https://roboflow.com
# Workflow: detect-and-classify
# ============================================
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_WORKSPACE=your-workspace-slug
ROBOFLOW_WORKFLOW=detect-and-classify
ROBOFLOW_ENDPOINT=https://serverless.roboflow.com/your-workspace/detect-and-classify

# ============================================
# 3D GENERATION — MESHY AI
# Sign up: https://meshy.ai
# ============================================
MESHY_API_KEY=your_meshy_api_key
MESHY_API_BASE_URL=https://api.meshy.ai/openapi/v1

# Cloudinary is required for deterministic Meshy image-to-3D
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional unsigned mode if you use an upload preset instead of API secret:
# CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_UPLOAD_FOLDER=vehicle-scans

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_EXPIRY=600
OTP_LENGTH=6
PASSWORD_SETUP_TOKEN_EXPIRY=3600

# ============================================
# FIREBASE ADMIN SDK (Server-side)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# ============================================
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<service-account@project.iam.gserviceaccount.com>
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ============================================
# LOCAL HTTPS (mkcert) — mobile WebAR / getUserMedia on LAN
# ============================================
# After: mkcert -install && mkcert 192.168.x.x localhost 127.0.0.1
# HTTPS_KEY_PATH=/absolute/path/to/_wildcard.your-key.pem
# HTTPS_CERT_PATH=/absolute/path/to/_wildcard.your.pem
# PORT=8080
# Point NEXT_PUBLIC_API_URL at https://<host>:<PORT> (see frontend/.env.local.example).
